# Environment Variables for KerfOS

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/kerfos

# ============================================
# STRIPE (Payment Processing)
# ============================================
# Your Stripe Secret Key (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here

# Stripe Webhook Secret (from https://dashboard.stripe.com/webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Stripe Price IDs (created by running /api/stripe/create-products)
STRIPE_PRICE_HOBBYIST=price_xxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxx
STRIPE_PRICE_SHOP=price_xxxxxxxxxxxxx

# ============================================
# FRONTEND (Public - exposed to browser)
# ============================================
NEXT_PUBLIC_STRIPE_PRICE_HOBBYIST=price_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_SHOP=price_xxxxxxxxxxxxx
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate a secure secret: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# SECURITY (GDPR & Compliance)
# ============================================
# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW=60

# CSRF Protection
CSRF_SECRET=your-csrf-secret-key-change-this

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://kerfos.com,https://www.kerfos.com

# ============================================
# LLM/AI (Optional - for chat assistant)
# ============================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
# or
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ============================================
# EMAIL (Optional - for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ============================================
# GDPR & PRIVACY
# ============================================
# Data Protection Officer Email
DPO_EMAIL=dpo@kerfos.com

# Privacy Contact Email
PRIVACY_EMAIL=privacy@kerfos.com

# Data Retention (days)
DATA_RETENTION_USER_DATA=730
DATA_RETENTION_AUDIT_LOGS=365
DATA_RETENTION_DELETED_DATA=30

# ============================================
# DEPLOYMENT
# ============================================
# Fly.io (backend)
FLY_API_TOKEN=xxxxxxxxxxxxx

# Vercel (frontend)
VERCEL_TOKEN=xxxxxxxxxxxxx

# Railway
RAILWAY_TOKEN=xxxxxxxxxxxxx

# ============================================
# ANALYTICS (Optional - requires user consent)
# ============================================
# Google Analytics Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================
# MONITORING (Optional)
# ============================================
# Sentry DSN for error tracking
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Logflare/Logpush for audit logs
LOGFLARE_SOURCE_TOKEN=xxxxxxxxxxxxx
